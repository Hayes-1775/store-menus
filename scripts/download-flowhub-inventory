#!/usr/bin/env node
/*
 * Flowhub inventory download entrypoint.
 *
 * This script is intentionally conservative: it uses the Codex Chrome browser
 * bridge when available, gives Chrome/password-manager autofill a short window
 * to complete login, and keeps the tab open while waiting for manual login or
 * verification handoff before continuing the export.
 */

const fs = require("node:fs");
const path = require("node:path");
const realExit = process.exit.bind(process);

const FLOWHUB_URL =
  process.env.FLOWHUB_INVENTORY_URL ||
  "https://app.flowhub.com/analytics/report/view/inventory#store_id=6453e245-f882-470d-92c2-8a47083d954c";

const OUT_DIR = path.resolve(process.env.FLOWHUB_DOWNLOAD_DIR || "downloads");
const LOGIN_WAIT_MS = Number(process.env.FLOWHUB_LOGIN_WAIT_MS || 45000);
const HANDOFF_WAIT_MS = Number(process.env.FLOWHUB_HANDOFF_WAIT_MS || 8 * 60 * 60 * 1000);

async function getPageState(tab) {
  return tab.playwright.evaluate(() => {
    const text = document.body?.innerText || "";
    const passwordInputs = Array.from(document.querySelectorAll('input[type="password"]'));
    const visiblePasswordInputs = passwordInputs.filter((input) => {
      const style = window.getComputedStyle(input);
      const rect = input.getBoundingClientRect();
      return style.visibility !== "hidden" && style.display !== "none" && rect.width > 0 && rect.height > 0;
    });

    return {
      title: document.title,
      text,
      hasPasswordField: visiblePasswordInputs.length > 0,
      hasFilledPasswordField: visiblePasswordInputs.some((input) => input.value.length > 0),
    };
  }, undefined, { timeoutMs: 10000 }).catch(() => ({
    title: "",
    text: "",
    hasPasswordField: false,
    hasFilledPasswordField: false,
  }));
}

function needsManualAuth(pageState) {
  return /verification|two[- ]factor|captcha/i.test(`${pageState.title}\n${pageState.text}`);
}

function looksLikeLogin(pageState) {
  return pageState.hasPasswordField || /sign in|log in/i.test(`${pageState.title}\n${pageState.text}`);
}

async function waitForAutofilledLogin(tab) {
  const deadline = Date.now() + LOGIN_WAIT_MS;

  while (Date.now() < deadline) {
    const pageState = await getPageState(tab);
    if (needsManualAuth(pageState)) {
      return { status: "manual_auth", pageState };
    }
    if (!looksLikeLogin(pageState)) {
      return { status: "logged_in", pageState };
    }

    if (pageState.hasFilledPasswordField) {
      const submitted = await tab.playwright.evaluate(() => {
        const passwordInput = document.querySelector('input[type="password"]');
        if (!passwordInput) return false;
        const form = passwordInput.closest("form");
        if (form) {
          form.requestSubmit();
          return true;
        }
        const buttons = Array.from(document.querySelectorAll('button, input[type="submit"]'));
        const submit = buttons.find((button) => /log in|sign in|continue|submit/i.test(button.innerText || button.value || ""));
        if (!submit) return false;
        submit.click();
        return true;
      }).catch(() => false);

      if (submitted) {
        await tab.playwright.waitForLoadState({ state: "domcontentloaded", timeoutMs: 15000 }).catch(() => {});
      }
    }

    await tab.playwright.waitForTimeout(1500);
  }

  return { status: "login_required", pageState: await getPageState(tab) };
}

async function waitForManualHandoff(tab, reason) {
  console.error(`${reason}. Waiting for manual completion in Chrome for ${Math.round(HANDOFF_WAIT_MS / 60000)} minutes.`);
  const deadline = Date.now() + HANDOFF_WAIT_MS;

  while (Date.now() < deadline) {
    const pageState = await getPageState(tab);
    if (!needsManualAuth(pageState) && !looksLikeLogin(pageState)) {
      return { status: "resolved", pageState };
    }
    await tab.playwright.waitForTimeout(3000);
  }

  return { status: "timeout", pageState: await getPageState(tab) };
}

async function main() {
  fs.mkdirSync(OUT_DIR, { recursive: true });
  const pluginRoot =
    process.env.CODEX_CHROME_PLUGIN_ROOT ||
    "/Users/mikehayes/.codex/plugins/cache/openai-bundled/chrome/26.519.81530";
  const clientPath = path.join(pluginRoot, "scripts", "browser-client.mjs");

  if (!fs.existsSync(clientPath)) {
    throw new Error(`Codex Chrome browser client not found at ${clientPath}`);
  }

  const { setupBrowserRuntime } = await import(`file://${clientPath}`);
  await setupBrowserRuntime({ globals: globalThis });
  const browser = await agent.browsers.get("extension");
  await browser.nameSession("Flowhub inventory export");
  const tab = await browser.tabs.new();
  await tab.goto(FLOWHUB_URL);
  await tab.playwright.waitForLoadState({ state: "domcontentloaded", timeoutMs: 30000 });

  const loginResult = await waitForAutofilledLogin(tab);
  if (loginResult.status === "manual_auth") {
    const handoffResult = await waitForManualHandoff(tab, "Flowhub requires verification, 2FA, or CAPTCHA");
    if (handoffResult.status !== "resolved") {
      await browser.tabs.finalize({ keep: [{ tab, status: "handoff" }] });
      throw new Error("Flowhub verification handoff timed out before the report page was available.");
    }
  }
  if (loginResult.status === "login_required") {
    const handoffResult = await waitForManualHandoff(tab, "Flowhub login did not complete after waiting for saved username/password autofill");
    if (handoffResult.status !== "resolved") {
      await browser.tabs.finalize({ keep: [{ tab, status: "handoff" }] });
      throw new Error("Flowhub login handoff timed out before the report page was available.");
    }
  }

  const candidates = [
    tab.playwright.getByRole("button", { name: /export|download|csv/i }),
    tab.playwright.getByText(/export|download|csv/i),
  ];

  for (const candidate of candidates) {
    try {
      const count = await candidate.count();
      if (!count) continue;
      const downloadPromise = tab.playwright.waitForEvent("download", { timeoutMs: 15000 });
      await candidate.first().click({ timeoutMs: 10000 });
      const download = await downloadPromise;
      if (!download || typeof download.saveAs !== "function") {
        throw new Error("Chrome download object does not support saveAs in this environment.");
      }
      const filename = `flowhub-inventory-${new Date().toISOString().slice(0, 10)}.csv`;
      const outPath = path.join(OUT_DIR, filename);
      await download.saveAs(outPath);
      await browser.tabs.finalize({});
      console.log(JSON.stringify({ path: outPath }, null, 2));
      return;
    } catch (error) {
      // Try the next selector candidate.
    }
  }

  await browser.tabs.finalize({ keep: [{ tab, status: "handoff" }] });
  throw new Error("Could not find a clear Flowhub CSV/export/download control on the report page.");
}

main().catch((error) => {
  console.error(error.message || String(error));
  realExit(1);
});
