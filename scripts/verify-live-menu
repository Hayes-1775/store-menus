#!/usr/bin/env python3
import argparse
import json
import subprocess
import sys
import time
from pathlib import Path
from typing import Any


def load_json(path: Path) -> dict[str, Any]:
    return json.loads(path.read_text(encoding="utf-8"))


def fetch_json(url: str) -> dict[str, Any]:
    result = subprocess.run(
        ["curl", "--fail", "--silent", "--show-error", "--location", url],
        check=True,
        capture_output=True,
        text=True,
    )
    return json.loads(result.stdout)


def summarize(menu: dict[str, Any]) -> dict[str, Any]:
    return {
        "generated_at": menu.get("generated_at"),
        "row_count": len(menu.get("rows", [])),
    }


def fail(message: str) -> None:
    print(f"FAIL: {message}", file=sys.stderr)
    raise SystemExit(1)


def normalize_base_url(url: str) -> str:
    return url.rstrip("/") + "/"


def expected_payloads() -> dict[str, dict[str, Any]]:
    return {
        "flower": summarize(load_json(Path("docs/menu-data.json"))),
        "vapes": summarize(load_json(Path("docs/vapes/menu-data.json"))),
        "vapes_page2": summarize(load_json(Path("docs/vapes/page2/menu-data.json"))),
    }


def live_urls(base_url: str) -> dict[str, str]:
    return {
        "flower": f"{base_url}menu-data.json",
        "vapes": f"{base_url}vapes/menu-data.json",
        "vapes_page2": f"{base_url}vapes/page2/menu-data.json",
    }


def fetch_live_state(urls: dict[str, str]) -> dict[str, dict[str, Any]]:
    return {name: summarize(fetch_json(url)) for name, url in urls.items()}


def main() -> None:
    parser = argparse.ArgumentParser()
    parser.add_argument("--pages-url", required=True)
    parser.add_argument("--timeout", type=int, default=180)
    parser.add_argument("--interval", type=int, default=5)
    args = parser.parse_args()

    base_url = normalize_base_url(args.pages_url)
    expected = expected_payloads()
    urls = live_urls(base_url)
    started_at = time.time()
    last_error: str | None = None
    last_live: dict[str, dict[str, Any]] | None = None

    while time.time() - started_at <= args.timeout:
        try:
            live = fetch_live_state(urls)
            last_live = live
            if live == expected:
                print(
                    json.dumps(
                        {
                            "status": "ok",
                            "pages_url": base_url,
                            "elapsed_seconds": round(time.time() - started_at, 2),
                            "expected": expected,
                            "live": live,
                        },
                        indent=2,
                    )
                )
                return
            last_error = "live site does not yet match local menu output"
        except (subprocess.CalledProcessError, json.JSONDecodeError) as exc:
            last_error = str(exc)

        time.sleep(args.interval)

    details = {
        "status": "timeout",
        "pages_url": base_url,
        "elapsed_seconds": round(time.time() - started_at, 2),
        "expected": expected,
        "live": last_live,
        "last_error": last_error,
    }
    print(json.dumps(details, indent=2), file=sys.stderr)
    fail("live GitHub Pages menu did not match local output before timeout")


if __name__ == "__main__":
    main()
