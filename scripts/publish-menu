#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT_DIR"

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "FAIL: not inside a git repository" >&2
  exit 1
fi

scripts/verify-menu >/tmp/store-menu-verify.json

if ! git remote get-url origin >/dev/null 2>&1; then
  echo "FAIL: no git remote named origin is configured. Create/connect a GitHub repo before publishing." >&2
  exit 2
fi

git add \
  .gitignore \
  config/menu_config.json \
  scripts/download-flowhub-inventory \
  scripts/extract-flower-menu \
  scripts/render-menu \
  scripts/run-daily-menu \
  scripts/verify-menu \
  scripts/publish-menu \
  docs/index.html \
  docs/menu-data.json \
  docs/latest.jpg \
  docs/archive/*.jpg

if git diff --cached --quiet; then
  echo "No publishable menu changes to commit."
  cat /tmp/store-menu-verify.json
  exit 0
fi

commit_date="$(date +%Y-%m-%d)"
git commit -m "Update flower menu ${commit_date}"
git push origin HEAD

cat /tmp/store-menu-verify.json
