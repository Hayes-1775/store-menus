#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
source "$ROOT_DIR/scripts/workflow-optimizer.sh"
WORKFLOW_NAME="store-menu-daily"
cd "$ROOT_DIR"

if command -v xcrun >/dev/null 2>&1; then
  GIT_BIN="$(xcrun -f git 2>/dev/null || true)"
fi
GIT_BIN="${GIT_BIN:-/usr/bin/git}"

if [[ ! -x "$GIT_BIN" ]]; then
  echo "FAIL: system git binary not found" >&2
  exit 1
fi

previous_head="$("$GIT_BIN" rev-parse HEAD)"

if ! "$GIT_BIN" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "FAIL: not inside a git repository" >&2
  exit 1
fi

workflow_run_timed_step "$WORKFLOW_NAME" "verify_before_publish" "local-script" \
  "local script" \
  sh -c 'scripts/verify-menu >/tmp/store-menu-verify.json'

if ! "$GIT_BIN" remote get-url origin >/dev/null 2>&1; then
  echo "FAIL: no git remote named origin is configured. Create/connect a GitHub repo before publishing." >&2
  exit 2
fi

workflow_run_timed_step "$WORKFLOW_NAME" "stage_publishable_files" "batch-git-add" \
  "batch" \
"$GIT_BIN" add \
  .gitignore \
  config/com.miraclegreens.store-menu-report.plist \
  config/menu_config.json \
  scripts/download-flowhub-inventory \
  scripts/extract-flower-menu \
  scripts/extract-vape-menu \
  scripts/workflow-optimizer.py \
  scripts/workflow-optimizer.sh \
  scripts/render-menu \
  scripts/render-vape-menu \
  scripts/run-daily-menu \
  scripts/run-vape-menu \
  scripts/run-vape-menu-page2 \
  scripts/send-store-menu-report-email \
  scripts/verify-menu \
  scripts/publish-menu \
  docs/index.html \
  docs/vendor/gsap.min.js \
  docs/menu-data.json \
  docs/latest.jpg \
  docs/archive/*.jpg \
  docs/vapes/index.html \
  docs/vapes/menu-data.json \
  docs/vapes/latest.jpg \
  docs/vapes/archive/*.jpg \
  docs/vapes/page2/index.html \
  docs/vapes/page2/menu-data.json \
  docs/vapes/page2/latest.jpg \
  docs/vapes/page2/archive/*.jpg

if "$GIT_BIN" diff --cached --quiet; then
  echo "No publishable menu changes to commit."
  workflow_run_timed_step "$WORKFLOW_NAME" "send_no_change_report" "local-script" \
    "local script" \
    scripts/send-store-menu-report-email \
      --send \
      --baseline-commit "$previous_head" \
      --publish-status no_changes \
      --published-commit "$previous_head"
  cat /tmp/store-menu-verify.json
  exit 0
fi

commit_date="$(date +%Y-%m-%d)"
workflow_run_timed_step "$WORKFLOW_NAME" "commit_menu_publish" "local-script" \
  "local script" \
  "$GIT_BIN" commit -m "Update store menus ${commit_date}"
workflow_run_timed_step "$WORKFLOW_NAME" "push_menu_publish" "api-git-push" \
  "api call" \
  "$GIT_BIN" push origin HEAD

published_head="$("$GIT_BIN" rev-parse HEAD)"
workflow_run_timed_step "$WORKFLOW_NAME" "send_publish_report" "local-script" \
  "local script" \
  scripts/send-store-menu-report-email \
    --send \
    --baseline-commit "$previous_head" \
    --publish-status published \
    --published-commit "$published_head"

cat /tmp/store-menu-verify.json
