#!/usr/bin/env python3
import json
import sys
from pathlib import Path

from PIL import Image


def fail(message: str) -> None:
    print(f"FAIL: {message}", file=sys.stderr)
    sys.exit(1)


def main() -> None:
    menu_path = Path("data/flower_menu.json")
    validation_path = Path("data/validation_report.json")
    image_path = Path("docs/latest.jpg")
    docs_data_path = Path("docs/menu-data.json")
    html_path = Path("docs/index.html")
    vape_image_path = Path("docs/vapes/latest.jpg")
    vape_docs_data_path = Path("docs/vapes/menu-data.json")
    vape_html_path = Path("docs/vapes/index.html")
    vape_page2_image_path = Path("docs/vapes/page2/latest.jpg")
    vape_page2_docs_data_path = Path("docs/vapes/page2/menu-data.json")
    vape_page2_html_path = Path("docs/vapes/page2/index.html")

    if not menu_path.exists():
        fail("missing data/flower_menu.json")
    if not validation_path.exists():
        fail("missing data/validation_report.json")
    if not image_path.exists():
        fail("missing docs/latest.jpg")
    if not docs_data_path.exists():
        fail("missing docs/menu-data.json")
    if not html_path.exists():
        fail("missing docs/index.html")
    for path in [
        vape_image_path,
        vape_docs_data_path,
        vape_html_path,
        vape_page2_image_path,
        vape_page2_docs_data_path,
        vape_page2_html_path,
    ]:
        if not path.exists():
            fail(f"missing {path}")

    menu = json.loads(menu_path.read_text(encoding="utf-8"))
    docs_menu = json.loads(docs_data_path.read_text(encoding="utf-8"))
    validation = json.loads(validation_path.read_text(encoding="utf-8"))
    vape_docs_menu = json.loads(vape_docs_data_path.read_text(encoding="utf-8"))
    vape_page2_docs_menu = json.loads(vape_page2_docs_data_path.read_text(encoding="utf-8"))
    rows = menu.get("rows", [])
    docs_rows = docs_menu.get("rows", [])
    names = {row["product_name"] for row in rows}

    if len(rows) != len(docs_rows):
        fail(f"docs/menu-data.json row count {len(docs_rows)} does not match data/flower_menu.json {len(rows)}")

    if "Jack Herer" not in names:
        fail("Jack Herer should be retained by duplicate tie handling")
    if len(rows) < 30:
        fail(f"unexpectedly low menu row count: {len(rows)}")
    if len(vape_docs_menu.get("rows", [])) < 20:
        fail(f"unexpectedly low vape menu row count: {len(vape_docs_menu.get('rows', []))}")
    if len(vape_page2_docs_menu.get("rows", [])) < 5:
        fail(f"unexpectedly low vape page 2 row count: {len(vape_page2_docs_menu.get('rows', []))}")
    low_stock_rows = [row for row in rows if row.get("quantity", 0) < 27]
    for row in low_stock_rows:
        if not row.get("closeout"):
            fail(f"{row['product_name']} is missing closeout with quantity {row['quantity']}")
    for row in rows:
        if row.get("quantity", 0) >= 27 and row.get("closeout"):
            fail(f"{row['product_name']} is marked closeout with quantity {row['quantity']}")

    img = Image.open(image_path)
    if img.size != (1080, 1920):
        fail(f"expected 1080x1920 image, got {img.size}")
    vape_img = Image.open(vape_image_path)
    if vape_img.size != (1080, 1920):
        fail(f"expected 1080x1920 vape image, got {vape_img.size}")
    vape_page2_img = Image.open(vape_page2_image_path)
    if vape_page2_img.size != (1080, 1920):
        fail(f"expected 1080x1920 vape page 2 image, got {vape_page2_img.size}")

    print(json.dumps({
        "status": "ok",
        "rows": len(rows),
        "vape_rows": len(vape_docs_menu.get("rows", [])),
        "vape_page2_rows": len(vape_page2_docs_menu.get("rows", [])),
        "missing_price_profiles": len(validation.get("missing_price_profiles", [])),
        "image": str(image_path),
        "html": str(html_path),
        "docs_data": str(docs_data_path),
        "size": img.size,
    }, indent=2))


if __name__ == "__main__":
    main()
