#!/usr/bin/env python3
import argparse
import json
import subprocess
import sys
from collections import defaultdict
from datetime import date, datetime, time, timedelta
from pathlib import Path
from typing import Dict, Iterable, List, Optional, Sequence, Tuple


ROOT = Path("/Users/mikehayes/Documents/Store Menus")
FLOWER_PATH = ROOT / "docs/menu-data.json"
VAPE1_PATH = ROOT / "docs/vapes/menu-data.json"
VAPE2_PATH = ROOT / "docs/vapes/page2/menu-data.json"
REPORT_ROLLOVER_HOUR = 22


def run_git(args: Sequence[str]) -> str:
    return subprocess.check_output(["git", *args], cwd=ROOT, text=True)


def verify_current_menu() -> None:
    result = subprocess.run(
        [str(ROOT / "scripts/verify-menu")],
        cwd=ROOT,
        text=True,
        capture_output=True,
    )
    if result.returncode == 0:
        return
    if result.stdout:
        print(result.stdout, file=sys.stderr, end="")
    if result.stderr:
        print(result.stderr, file=sys.stderr, end="")
    raise SystemExit(result.returncode)


def load_json(path: Path) -> dict:
    return json.loads(path.read_text(encoding="utf-8"))


def load_rows(path: Path) -> List[dict]:
    return load_json(path).get("rows", [])


def load_rows_from_git(commit: str, path_in_repo: str) -> List[dict]:
    return json.loads(run_git(["show", f"{commit}:{path_in_repo}"])).get("rows", [])


def load_rows_at(path: Path, path_in_repo: str, source_commit: Optional[str]) -> List[dict]:
    if source_commit:
        return load_rows_from_git(source_commit, path_in_repo)
    return load_rows(path)


def previous_snapshot_line(pathspecs: Sequence[str], before_date: datetime) -> Optional[Tuple[str, str, str]]:
    output = run_git(
        [
            "log",
            f"--before={before_date.strftime('%Y-%m-%d %H:%M:%S')}",
            "--date=iso",
            "--pretty=format:%H|%ad|%s",
            "--",
            *pathspecs,
        ]
    ).splitlines()
    if not output:
        return None
    return tuple(output[0].split("|", 2))  # type: ignore[return-value]


def key_by_name(rows: Iterable[dict]) -> Dict[str, dict]:
    return {row["product_name"]: row for row in rows}


def fmt_qty(value: Optional[float]) -> str:
    if value is None:
        return "not on menu"
    return f"{value:g}"


def fmt_diff(old_value: Optional[float], new_value: Optional[float]) -> str:
    if old_value is None and new_value is None:
        return "0"
    if old_value is None:
        return f"{new_value:g}"
    if new_value is None:
        return f"{old_value:g}"
    return f"{(old_value - new_value):g}"


def inventory_delta(old_value: Optional[float], new_value: Optional[float]) -> float:
    if old_value is None and new_value is None:
        return 0
    if old_value is None:
        return -float(new_value or 0)
    if new_value is None:
        return float(old_value)
    return float(old_value) - float(new_value)


def fmt_amount(value: float, unit: str = "") -> str:
    suffix = unit if unit else ""
    return f"{value:g}{suffix}"


def fmt_amount_abs(value: float, unit: str = "") -> str:
    return fmt_amount(abs(value), unit)


def fmt_units(value: float, singular: str, plural: str) -> str:
    unit = singular if abs(value) == 1 else plural
    return f"{value:g} {unit}"


def fmt_product_delta(old_value: Optional[float], new_value: Optional[float], unit: str = "") -> str:
    return fmt_amount(inventory_delta(old_value, new_value), unit)


def format_date_label(date_text: str) -> str:
    return datetime.strptime(date_text[:19], "%Y-%m-%d %H:%M:%S").strftime("%B %-d, %Y")


def format_day_label(day: date) -> str:
    return day.strftime("%A, %B %-d, %Y")


def sales_day_for_run(run_at: datetime) -> date:
    if run_at.hour >= REPORT_ROLLOVER_HOUR:
        return run_at.date()
    return run_at.date() - timedelta(days=1)


def unchanged_rows_between(
    pathspec: str,
    current_path: Path,
    before_date: datetime,
    source_commit: Optional[str],
) -> Tuple[Optional[str], List[Tuple[str, float]]]:
    baseline = previous_snapshot_line([pathspec], before_date)
    if not baseline:
        return None, []
    commit, base_date, _ = baseline
    current_rows = load_rows_at(current_path, pathspec, source_commit)
    old_rows = load_rows_from_git(commit, pathspec)
    old = key_by_name(old_rows)
    new = key_by_name(current_rows)
    unchanged: List[Tuple[str, float]] = []
    for name in sorted(set(old) & set(new)):
        old_qty = old[name].get("quantity")
        new_qty = new[name].get("quantity")
        if old_qty == new_qty and old_qty is not None:
            unchanged.append((name, float(old_qty)))
    return base_date, unchanged


def flower_section(sales_day: date, source_commit: Optional[str]) -> str:
    baseline = previous_snapshot_line(["docs/menu-data.json"], datetime.combine(sales_day, time.min))
    if not baseline:
        return "FLOWER SELL-THROUGH\nNo prior published flower snapshot found.\n"

    commit, base_date, _ = baseline
    current_rows = load_rows_at(FLOWER_PATH, "docs/menu-data.json", source_commit)
    old_rows = load_rows_from_git(commit, "docs/menu-data.json")
    old = key_by_name(old_rows)
    new = key_by_name(current_rows)

    sold_entries: List[Tuple[str, float, bool]] = []
    restocked_entries: List[Tuple[str, float, bool]] = []
    unchanged: List[Tuple[str, float]] = []

    for name in sorted(set(old) | set(new)):
        old_qty = old[name].get("quantity") if name in old else None
        new_qty = new[name].get("quantity") if name in new else None
        delta = inventory_delta(old_qty, new_qty)
        if delta > 0:
            sold_entries.append((name, delta, name not in new))
        elif delta < 0:
            restocked_entries.append((name, delta, name not in old))
        elif name in old and old_qty is not None:
            unchanged.append((name, float(old_qty)))

    sold_entries.sort(key=lambda item: (-item[1], item[0]))
    restocked_entries.sort(key=lambda item: (item[1], item[0]))

    lines = []
    lines.append("FLOWER SELL-THROUGH")
    lines.append(
        f"Method: net inventory sold on {format_day_label(sales_day)} versus the prior published flower snapshot from {format_date_label(base_date)}."
    )
    sold_grams = sum(delta for _, delta, _ in sold_entries)
    sold_sku_count = len(sold_entries)
    top_flower = sold_entries[0] if sold_entries else None
    lines.append(f"- Net flower sold: {fmt_amount(sold_grams, 'g')} across {sold_sku_count} products")
    lines.append(f"- No movement: {len(unchanged)} products")
    if top_flower:
        lines.append(f"- Top mover: {top_flower[0]} ({fmt_amount(top_flower[1], 'g')})")
    if restocked_entries:
        lines.append(f"- Restocked or newly added: {len(restocked_entries)} products")
    lines.append("")

    if sold_entries:
        lines.append("SOLD")
        for name, delta, removed_from_menu in sold_entries:
            status = " (off menu)" if removed_from_menu else ""
            lines.append(f"- {name}: {fmt_amount(delta, 'g')}{status}")
        lines.append("")
    else:
        lines.append("SOLD")
        lines.append("- No flower sell-through recorded.")
        lines.append("")

    if restocked_entries:
        lines.append("RESTOCKED / ADDED")
        for name, delta, newly_added in restocked_entries:
            status = " (new on menu)" if newly_added else ""
            lines.append(f"- {name}: {fmt_amount_abs(delta, 'g')}{status}")
        lines.append("")

    if unchanged:
        lines.append("NO MOVEMENT")
        for name, _ in unchanged:
            lines.append(f"- {name}")
        lines.append("")

    three_day_base_date, three_day_unchanged = unchanged_rows_between(
        "docs/menu-data.json",
        FLOWER_PATH,
        datetime.combine(sales_day, time.min) - timedelta(days=2),
        source_commit,
    )
    if three_day_base_date and three_day_unchanged:
        lines.append("NO FLOWER MOVEMENT IN THE LAST 3 DAYS")
        lines.append(f"Baseline: {format_date_label(three_day_base_date)}")
        for name, _ in three_day_unchanged:
            lines.append(f"- {name}")
        lines.append("")

    hidden_gem_sales = []
    hidden_gem_count = 0
    for name in sorted(set(old) & set(new)):
        if not old[name].get("no_recent_sales"):
            continue
        hidden_gem_count += 1
        sold = inventory_delta(old[name].get("quantity"), new[name].get("quantity"))
        if sold > 0:
            hidden_gem_sales.append((name, sold))

    if hidden_gem_count:
        hidden_gem_sold_total = sum(sold for _, sold in hidden_gem_sales)
        lines.append("BLUE DIAMOND / HIDDEN GEM CHECK")
        if hidden_gem_sales:
            lines.append(
                f"- Sold: {len(hidden_gem_sales)} of {hidden_gem_count} tracked products, totaling {fmt_amount(hidden_gem_sold_total, 'g')}"
            )
            for name, sold in hidden_gem_sales:
                lines.append(f"- {name}: {fmt_amount(sold, 'g')}")
        else:
            lines.append(f"- Sold: 0 of {hidden_gem_count} tracked products")
        lines.append("")

    return "\n".join(lines)


def vape_section(sales_day: date, source_commit: Optional[str]) -> str:
    baseline = previous_snapshot_line(
        ["docs/vapes/menu-data.json", "docs/vapes/page2/menu-data.json"],
        datetime.combine(sales_day, time.min),
    )
    if not baseline:
        return "VAPE SELL-THROUGH\nNo prior published vape snapshot found.\n"

    commit, base_date, _ = baseline
    old_rows = load_rows_from_git(commit, "docs/vapes/menu-data.json") + load_rows_from_git(
        commit, "docs/vapes/page2/menu-data.json"
    )
    new_rows = load_rows_at(VAPE1_PATH, "docs/vapes/menu-data.json", source_commit) + load_rows_at(
        VAPE2_PATH, "docs/vapes/page2/menu-data.json", source_commit
    )
    old = key_by_name(old_rows)
    new = key_by_name(new_rows)
    groups: Dict[Tuple[str, str], List[Tuple[str, Optional[float], Optional[float]]]] = defaultdict(list)
    sold_groups: Dict[Tuple[str, str], List[Tuple[str, float]]] = defaultdict(list)
    restocked_groups: Dict[Tuple[str, str], List[Tuple[str, float]]] = defaultdict(list)
    sold_units_total = 0.0

    for name in sorted(set(old) | set(new)):
        previous = old.get(name)
        current = new.get(name)
        sample = current or previous
        brand = sample.get("brand", "Unknown")
        process = sample.get("process") or "Unspecified"
        old_qty = previous.get("quantity") if previous else None
        new_qty = current.get("quantity") if current else None
        delta = inventory_delta(old_qty, new_qty)
        if delta > 0:
            sold_groups[(brand, process)].append((name, delta))
            sold_units_total += delta
        elif delta < 0:
            restocked_groups[(brand, process)].append((name, delta))

    lines = []
    lines.append("VAPE SELL-THROUGH")
    lines.append(
        f"Method: net inventory sold on {format_day_label(sales_day)} versus the prior published vape snapshot from {format_date_label(base_date)}."
    )
    sold_product_count = sum(len(entries) for entries in sold_groups.values())
    top_group = None
    if sold_groups:
        top_group = max(
            sold_groups.items(),
            key=lambda item: (sum(delta for _, delta in item[1]), item[0][0], item[0][1]),
        )
    lines.append(f"- Net vape sold: {fmt_units(sold_units_total, 'unit', 'units')} across {sold_product_count} products")
    if top_group:
        group_units = sum(delta for _, delta in top_group[1])
        lines.append(f"- Top brand / process: {top_group[0][0]} / {top_group[0][1]} ({fmt_units(group_units, 'unit', 'units')})")
    if restocked_groups:
        lines.append(f"- Restocked or newly added: {sum(len(entries) for entries in restocked_groups.values())} products")
    lines.append("")

    if sold_groups:
        lines.append("SOLD")
        for brand, process in sorted(sold_groups):
            lines.append(f"{brand} / {process}")
            sold_entries = sorted(sold_groups[(brand, process)], key=lambda item: (-item[1], item[0]))
            sold_units = sum(delta for _, delta in sold_entries)
            lines.append(f"- Total sold: {fmt_units(sold_units, 'unit', 'units')}")
            for name, delta in sold_entries:
                lines.append(f"- {name}: {fmt_units(delta, 'unit', 'units')}")
            lines.append("")
    else:
        lines.append("SOLD")
        lines.append("- No vape sell-through recorded.")
        lines.append("")

    if restocked_groups:
        lines.append("RESTOCKED / ADDED")
        for brand, process in sorted(restocked_groups):
            lines.append(f"{brand} / {process}")
            restock_entries = sorted(restocked_groups[(brand, process)], key=lambda item: (item[1], item[0]))
            for name, delta in restock_entries:
                lines.append(f"- {name}: {fmt_units(abs(delta), 'unit', 'units')}")
            lines.append("")

    return "\n".join(lines).rstrip()


def build_report(run_at: datetime, source_commit: Optional[str] = None) -> str:
    sales_day = sales_day_for_run(run_at)
    parts = [
        "MIRACLE GREENS",
        "STORE SELL-THROUGH RECAP",
        "",
        f"Sales Day: {format_day_label(sales_day)}",
        f"Sent: {run_at.strftime('%A, %B %-d, %Y at %-I:%M %p %Z')}",
        "",
        "This report shows what sold after close based on net inventory change versus the prior published menu snapshot.",
        "",
        flower_section(sales_day, source_commit),
        "",
        vape_section(sales_day, source_commit),
    ]
    return "\n".join(parts).strip() + "\n"


def send_mail(recipient: str, subject: str, body: str) -> None:
    script = """
on run argv
  set recipientAddress to item 1 of argv
  set messageSubject to item 2 of argv
  set messageBody to item 3 of argv
  tell application "Mail"
    set newMessage to make new outgoing message with properties {subject:messageSubject, content:messageBody & return & return, visible:false}
    tell newMessage
      make new to recipient at end of to recipients with properties {address:recipientAddress}
      send
    end tell
  end tell
end run
"""
    subprocess.run(["osascript", "-", recipient, subject, body], input=script, text=True, check=True)


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--to", required=True)
    parser.add_argument("--send", action="store_true")
    parser.add_argument("--subject-prefix", default="Store Sell-Through Recap")
    parser.add_argument(
        "--run-at",
        help="Override the local run timestamp in ISO format, e.g. 2026-06-17T22:00:00-07:00",
    )
    parser.add_argument(
        "--source-commit",
        help="Read menu snapshot data from a specific git commit instead of the working tree.",
    )
    args = parser.parse_args()

    run_at = (
        datetime.fromisoformat(args.run_at).astimezone()
        if args.run_at
        else datetime.now().astimezone()
    )
    if not args.source_commit:
        verify_current_menu()
    sales_day = sales_day_for_run(run_at)
    report = build_report(run_at, args.source_commit)
    subject = f"{args.subject_prefix} - {sales_day.strftime('%Y-%m-%d')}"

    if not args.send:
      sys.stdout.write(report)
      return 0

    send_mail(args.to, subject, report)
    print(f"Sent report to {args.to} with subject: {subject}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
